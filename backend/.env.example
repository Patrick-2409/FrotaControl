# Copie para .env e preencha. Nunca commite .env com segredos reais.

PORT=4000
NODE_ENV=development

# Obrigatório em todos os ambientes
DATABASE_URL=postgres://postgres:postgres@localhost:5432/frotacontrol
JWT_SECRET=troque-esta-chave-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=30d

# URL pública do backend (PDFs/logos absolutos). No Render: https://seu-servico.onrender.com
# Se vazio, o servidor deduz de X-Forwarded-* nos requests.
PUBLIC_BASE_URL=
BACKEND_PUBLIC_URL=

# CORS: padrão em produção é permissivo (origin: true) para facilitar deploy.
# Para restringir origens, defina CORS_STRICT=true e liste em CORS_ORIGINS.
CORS_STRICT=false
CORS_ORIGINS=

# PostgreSQL: em produção o SSL é ligado por padrão. Local sem SSL: DATABASE_SSL=false
DATABASE_SSL=

MONITORING_DSN=
AUTH_DIAGNOSTIC_STRICT=false
USER_NAME_DIAGNOSTIC_STRICT=false

# Puppeteer (exportação PDF no servidor). No Render Linux pode exigir Chrome do sistema.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_LAUNCH_TIMEOUT_MS=20000

# IA operacional (somente backend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=40000
OP_AI_MONTHLY_LIMIT=10
OP_AI_COOLDOWN_SECONDS=60

# Upload persistente em produção (Render): Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
